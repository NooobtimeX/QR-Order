# Set the default behavior to CRLF for all text files
* text=auto eol=crlf

# Explicitly set CRLF for specific file types
*.bat      eol=crlf
*.cmd      eol=crlf
*.sh       eol=crlf
*.yml      eol=crlf
*.yaml     eol=crlf
*.json     eol=crlf
*.js       eol=crlf
*.ts       eol=crlf
*.jsx      eol=crlf
*.tsx      eol=crlf
*.vue      eol=crlf
*.html     eol=crlf
*.css      eol=crlf
*.scss     eol=crlf
*.md       eol=crlf
*.txt      eol=crlf

# Binary files should be treated as binary and should not be modified.
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.pdf      binary
*.zip      binary
*.woff     binary
*.woff2    binary
*.ttf      binary
*.eot      binary
*.otf      binary
